.san/.san_hashes.json
.san/_cache/
# NOTE: commit .san/_index.json and .san/src/**/*.san — they are prebuilt
# knowledge shared across the team.

# ============================================================
# Internal AI / agent-assisted workflow artifacts (ALL ignored)
# These contain personal context, absolute paths, internal team
# personas, and unfinished design decisions. NOT for public repo.
# ============================================================

# Claude Code per-project config (reveals AI workflow internals)
.claude/

# Agent-internal project context (has personal/career framing,
# absolute /Users paths, internal agent identities)
CLAUDE.md

# Agent-generated working docs (PRD drafts, architecture decisions,
# sprint plans, test strategy — all internal). Curated /docs for
# the public docs site go in a separate location later.
docs/

# Agent-brain SAN compressed code cache + index
.san/

# Project-level MCP server config — has user-specific absolute paths
.mcp.json

# Agent draft / scratch markdown anywhere in the tree
**/*.agent-draft.md
**/*.agent-scratch.md

# ============================================================
# Xcode (demo-app/iosApp/)
# ============================================================
demo-app/iosApp/**/xcuserdata/
demo-app/iosApp/**/.DS_Store
demo-app/iosApp/**/*.xcuserstate
demo-app/iosApp/**/*.xcworkspace/xcuserdata/
demo-app/iosApp/**/build/
demo-app/iosApp/**/Pods/
demo-app/iosApp/**/*.xcworkspace

# ============================================================
# Secrets — defensive (should NEVER appear in this repo)
# ============================================================
# Generic env files
.env
.env.*
!.env.example

# GPG / signing keys (for Maven Central publishing — NEVER commit)
*.asc
*.gpg
*.key
*.p12
*.pem
secring.*
pubring.*
.gnupg/

# Sonatype / Maven Central credentials
# Project-level gradle.properties IS committed (build settings only — never put creds here).
# User-level ~/.gradle/gradle.properties holds Sonatype/GPG creds and is naturally outside
# the repo tree.
local.properties
secring.*.gpg
*.p12
*.pfx
*.jks
*.keystore

# AWS / GCP / cloud credentials
.aws/
credentials.json
service-account*.json
*.pem.key

# IDE-stored credentials
.idea/sonarlint*
.idea/httpRequests/
.idea/replstate.xml
